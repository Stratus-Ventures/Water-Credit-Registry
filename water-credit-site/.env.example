# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Mapbox (optional) — Overview page US map.
# Without a token the Overview map falls back to a styled US projection.
# Get a public token at https://account.mapbox.com/access-tokens/
PUBLIC_MAPBOX_TOKEN=""
